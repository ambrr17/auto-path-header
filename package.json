{
  "name": "auto-path-header",
  "displayName": "Auto Path Header",
  "description": "Automatically inserts the relative path of the file as a comment on the first line.",
  "version": "1.0.0",
  "publisher": "Niklis",
  "engines": {
    "vscode": "^1.85.0"
  },
  "author": "Niklis",
  "repository": {
    "type": "git",
    "url": "https://github.com/ambrr17/auto-path-header.git"
  },
  "icon": "images/icon.png",
  "keywords": [
    "vscode",
    "comment",
    "header",
    "path",
    "file path",
    "automation"
  ],
  "categories": [
    "Other"
  ],
  "license": "MIT",
  "activationEvents": [
    "onCommand:autoPathHeader.insertComment",
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "files": [
    "dist/**",
    "media/**",
    "images/**",
    "README.md",
    "CHANGELOG.md",
    "LICENSE",
    "package.json"
  ],
  "contributes": {
    "commands": [
      {
        "command": "autoPathHeader.insertComment",
        "title": "Insert Path Comment",
        "category": "Auto Path Header"
      }
    ],
    "configuration": {
      "title": "Auto Path Header",
      "properties": {
        "autoPathHeader.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable/disable automatic comment insertion",
          "scope": "resource"
        },
        "autoPathHeader.language": {
          "type": "string",
          "enum": [
            "auto",
            "en",
            "ru"
          ],
          "default": "auto",
          "description": "Language for extension messages (auto = system language)"
        },
        "autoPathHeader.updateOnRename": {
          "type": "boolean",
          "default": true,
          "description": "Automatically update path comment when file is renamed or moved",
          "scope": "resource"
        },
        "autoPathHeader.askBeforeUpdate": {
          "type": "boolean",
          "default": false,
          "description": "Ask for confirmation before updating path comment (only works when updateOnRename is true)",
          "scope": "resource"
        },
        "autoPathHeader.formatTemplate": {
          "type": "string",
          "default": "{comment}",
          "description": "Template for generated comment. Supports {comment}, {path}, {prefix}, {suffix}",
          "scope": "resource"
        },
        "autoPathHeader.disabledExtensions": {
          "type": "array",
          "description": "List of file extensions where automatic insertion is disabled (e.g. ['.txt', '.log'])",
          "default": [],
          "items": {
            "type": "string"
          },
          "scope": "resource"
        },
        "autoPathHeader.allowedOnlyExtensions": {
          "type": "array",
          "description": "List of file extensions that are allowed for automatic insertion. Extensions not in this list will be ignored. This setting is applied before disabledExtensions.",
          "default": [
            ".js",
            ".ts",
            ".jsx",
            ".tsx",
            ".java",
            ".c",
            ".cpp",
            ".h",
            ".hpp",
            ".cs",
            ".go",
            ".rs",
            ".swift",
            ".kt",
            ".kts",
            ".php",
            ".py",
            ".sh",
            ".bash",
            ".zsh",
            ".rb",
            ".pl",
            ".pm",
            ".env",
            ".txt",
            ".md",
            ".markdown",
            ".css",
            ".scss",
            ".sass",
            ".less",
            ".sql",
            ".lua",
            ".hs",
            ".html",
            ".htm",
            ".xml",
            ".svg",
            ".dockerfile",
            ".Dockerfile",
            ".gitignore",
            ".npmrc",
            ".yml",
            ".yaml",
            ".json",
            ".jsonc",
            ".toml",
            ".ini",
            ".bat",
            ".cmd"
          ],
          "items": {
            "type": "string"
          },
          "scope": "resource"
        },
        "autoPathHeader.allowedOnlyDirectories": {
          "type": "array",
          "description": "List of directories or glob patterns to limit automatic insertion (relative paths from workspace root). When non-empty, files not matching any entry are ignored.",
          "default": ["."],
          "items": {
            "type": "string"
          },
          "scope": "resource"
        },
        "autoPathHeader.customTemplatesByExtension": {
          "type": "object",
          "description": "Custom templates by file extension. Key is the file extension (e.g. '.ts', '.js'), specific filename (e.g. 'Dockerfile.dev'), or '*' for all files, value is the template string. Supports {path}, {filename}, {dirname} placeholders",
          "default": {},
          "additionalProperties": {
            "type": "string"
          },
          "scope": "resource"
        },
        "autoPathHeader.ignoredDirectories": {
          "type": "array",
          "description": "List of directories or glob patterns to ignore (relative paths from workspace root)",
          "default": [
            "node_modules",
            "vendor",
            "vendors",
            "dist",
            "build",
            ".git",
            ".svn",
            ".hg",
            "target",
            "out",
            "bin"
          ],
          "items": {
            "type": "string"
          },
          "scope": "resource"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "tsc -p ./",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "package": "vsce package",
    "test": "npm run compile && node ./out-test/test/runTest.js",
    "test:it": "npm run compile && node ./out-it/runTest.js",
    "compile-test": "tsc -p ./tsconfig.test.json",
    "compile-it": "tsc -p ./tsconfig.it.json",
    "test:unit:report": "npm run compile-test && node ./out-test/test/runTest.js || exit 0",
    "test:it:report": "npm run compile-it && node ./out-it/runTest.js || exit 0",
    "test:all:report": "npm run compile-test && npm run compile-it && npm run test:unit:report && npm run test:it:report"
  },
  "dependencies": {
    "minimatch": "^9.0.4"
  },
  "devDependencies": {
    "@types/glob": "^8.0.0",
    "@types/mocha": "^10.0.0",
    "@types/node": "^24.0.4",
    "@types/vscode": "^1.85.0",
    "@types/minimatch": "^5.1.2",
    "@vscode/test-electron": "^2.5.2",
    "glob": "^10.0.0",
    "mocha": "^10.0.0",
    "typescript": "^5.0.0",
    "vsce": "^2.14.0"
  }
}